{
  "name": "@onuracar-dev/nimblejs",
  "version": "0.1.0",
  "description": "A nimble, signals-based state management library.",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/nimblejs.umd.js",
  "module": "./dist/nimblejs.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/nimblejs.es.js",
      "require": "./dist/nimblejs.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "test": "vitest run",
    "build": "tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^5.2.2",
    "vite": "^5.2.0",
    "vite-plugin-dts": "^3.8.1",
    "vitest": "^4.1.10"
  }
}
